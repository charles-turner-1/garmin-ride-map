# Copy to ingest/.env (gitignored) and fill in. In CI these are GitHub secrets.
# Never put real values in THIS file — it is committed.

# Base64 tokenstore from `python ingest/save_token.py` (required)
GARMIN_TOKENSTORE_B64=

# Privacy clip: drop GPS points within PRIVACY_RADIUS_M metres of your home
# point, then jitter the exposed endpoints by up to PRIVACY_JITTER_M metres so
# they don't trace a clean circle around home. Format is "lat,lng".
# Keep your REAL home point in ingest/.env only, never here.
PRIVACY_CENTER=-31.95,115.86
PRIVACY_RADIUS_M=500
PRIVACY_JITTER_M=200

# Garmin activity typeKeys to include (comma-separated). Leave BLANK to grab any
# cycling activity (matched by parent type). Set explicit keys to narrow, e.g.
# RIDE_TYPES=road_biking,gravel_cycling
RIDE_TYPES=

# Years of history to pull
SINCE_YEARS=4

# Line simplification tolerance in degrees (~0.0001 ≈ 11 m)
SIMPLIFY_TOLERANCE=0.0001
